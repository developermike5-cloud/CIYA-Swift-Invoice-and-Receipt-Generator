{
  "entities": {
    "Analytics": {
      "title": "Application Analytics",
      "description": "Global counters for document downloads",
      "type": "object",
      "properties": {
        "invoiceDownloads": {
          "type": "integer",
          "description": "Total number of invoice PDFs downloaded"
        },
        "receiptDownloads": {
          "type": "integer",
          "description": "Total number of receipt PDFs downloaded"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last time the counters were updated"
        }
      },
      "required": ["invoiceDownloads", "receiptDownloads", "updatedAt"]
    },
    "ExportHistory": {
      "title": "Export History",
      "description": "Log entry of a generated and downloaded document",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["invoice", "receipt"],
          "description": "Document type, either invoice or receipt"
        },
        "businessName": {
          "type": "string",
          "description": "Name of the business generating the document"
        },
        "customerName": {
          "type": "string",
          "description": "Name of the billed customer"
        },
        "number": {
          "type": "string",
          "description": "Invoice or receipt number"
        },
        "date": {
          "type": "string",
          "format": "date-time",
          "description": "ISO timestamp of the download event"
        },
        "timestamp": {
          "type": "string",
          "description": "Firebase server timestamp of the log entry"
        }
      },
      "required": ["type", "businessName", "customerName", "number", "date", "timestamp"]
    }
  },
  "firestore": {
    "/stats/global": {
      "schema": "Analytics",
      "description": "Single document holding global stats"
    },
    "/exports_history/{historyId}": {
      "schema": "ExportHistory",
      "description": "Logs of all downloaded documents"
    }
  }
}
