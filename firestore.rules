rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Analytics stats
    match /stats/{docId} {
      allow read: if docId == 'global';
      
      allow create: if docId == 'global' 
        && incoming().keys().hasAll(['invoiceDownloads', 'receiptDownloads', 'updatedAt'])
        && incoming().keys().size() == 3
        && incoming().invoiceDownloads is int
        && incoming().receiptDownloads is int
        && incoming().updatedAt == request.time;

      allow update: if docId == 'global'
        && incoming().keys().hasAll(['invoiceDownloads', 'receiptDownloads', 'updatedAt'])
        && incoming().keys().size() == 3
        && incoming().updatedAt == request.time
        // Ensure values only go UP and only one at a time (or just up)
        && (
          (incoming().invoiceDownloads == existing().invoiceDownloads + 1 && incoming().receiptDownloads == existing().receiptDownloads) ||
          (incoming().receiptDownloads == existing().receiptDownloads + 1 && incoming().invoiceDownloads == existing().invoiceDownloads)
        );
    }

    // Exports history
    match /exports_history/{historyId} {
      allow read: if historyId is string;

      allow create: if historyId is string
        && incoming().keys().hasAll(['type', 'businessName', 'customerName', 'number', 'date', 'timestamp'])
        && incoming().keys().size() == 6
        && (incoming().type == 'invoice' || incoming().type == 'receipt')
        && incoming().businessName is string
        && incoming().businessName.size() <= 200
        && incoming().customerName is string
        && incoming().customerName.size() <= 200
        && incoming().number is string
        && incoming().number.size() <= 50
        && incoming().date is string
        && incoming().date.size() <= 100
        && incoming().timestamp == request.time;
    }
  }
}
